{
  "name": "ebg-project",
  "version": "1.2.0",
  "description": "Enterprise Business Graph — AI-native enterprise management platform",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:invariants": "vitest run tests/invariants",
    "lint": "eslint src/ tests/ --ext .ts",
    "db:neo4j:init": "tsx scripts/neo4j-init.ts",
    "db:pg:migrate": "tsx scripts/pg-migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@apollo/server": "^5.4.0",
    "@as-integrations/express5": "^1.1.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "graphql": "^16.13.2",
    "helmet": "^8.1.0",
    "kafkajs": "^2.2.4",
    "neo4j-driver": "^6.0.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^11.0.0",
    "eslint": "^10.1.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
